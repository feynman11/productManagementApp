// ──────────────────────────────────────────────────────
// ProductPlan — Prisma 7 Schema
// Single source of truth for all data models.
// Run `bunx prisma generate` to produce TypeScript types
// and Zod validation schemas.
// ──────────────────────────────────────────────────────

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

generator zod {
  provider          = "prisma-zod-generator"
  output            = "../src/generated/zod"
  modelSuffix       = "Schema"
  isGenerateSelect  = true
  isGenerateInclude = true
}

// ──────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────

enum ClientStatus {
  ACTIVE
  INACTIVE
  PENDING_SETUP
  SUSPENDED
}

enum OrgRole {
  ADMIN
  CONTRIBUTOR
  VIEWER
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum ProductMemberRole {
  OWNER
  MEMBER
  VIEWER
}

enum IdeaStatus {
  SUBMITTED
  UNDER_REVIEW
  CONVERTED
  IN_PROGRESS
  COMPLETED
  REJECTED
  DUPLICATE
}

enum RoadmapItemStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReleaseStatus {
  PLANNED
  IN_PROGRESS
  RELEASED
  CANCELLED
}

enum IssueSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

enum ActionItemStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum ActionItemPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  IDEA_VOTED
  IDEA_STATUS_CHANGED
  IDEA_COMMENTED
  ISSUE_ASSIGNED
  ISSUE_COMMENTED
}

// ──────────────────────────────────────────────────────
// User & Multi-Tenancy Models
// ──────────────────────────────────────────────────────

model AppUser {
  id           String  @id @default(cuid())
  clerkUserId  String  @unique
  /// @zod.string.email()
  email        String?
  name         String?
  avatarUrl    String?
  isSuperAdmin Boolean @default(false)

  activeClient   Client? @relation("activeClient", fields: [activeClientId], references: [id])
  activeClientId String?

  memberships        ClientUser[]
  productMemberships ProductMember[]

  // Reverse relations for authored/reported/assigned entities
  authoredIdeas    Idea[]    @relation("IdeaAuthor")
  reportedIssues   Issue[]   @relation("IssueReporter")
  assignedIssues   Issue[]   @relation("IssueAssignee")
  authoredComments Comment[] @relation("CommentAuthor")
  raisedActions    ActionItem[] @relation("ActionRaisedBy")
  assignedActions  ActionItem[] @relation("ActionAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activeClientId])
}

model Client {
  id     String       @id @default(cuid())
  /// @zod.string.min(1).max(100)
  name   String       @unique
  /// @zod.string.min(1).max(50).regex(/^[a-z0-9-]+$/)
  slug   String       @unique
  status ClientStatus @default(PENDING_SETUP)
  isDemo Boolean      @default(false)

  clientUsers    ClientUser[]
  products       Product[]
  productMembers ProductMember[]
  ideas          Idea[]
  roadmaps       Roadmap[]
  issues         Issue[]
  actionItems    ActionItem[]
  notifications  Notification[]
  activeUsers    AppUser[]      @relation("activeClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ClientUser {
  id     String  @id @default(cuid())
  role   OrgRole
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
}

// ──────────────────────────────────────────────────────
// Core Business Models
// ──────────────────────────────────────────────────────

model Product {
  id          String        @id @default(cuid())
  /// @zod.string.min(1).max(100)
  name        String
  /// @zod.string.max(500)
  description String?
  vision      String?
  strategy    String?
  status      ProductStatus @default(ACTIVE)
  /// @zod.string.regex(/^#[0-9A-Fa-f]{6}$/)
  color       String        @default("#3B82F6")
  icon        String?

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  members      ProductMember[]
  ideas        Idea[]
  roadmaps     Roadmap[]
  issues       Issue[]
  goals        Goal[]
  actionItems  ActionItem[]
  customFields CustomField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@unique([clientId, name])
}

model ProductMember {
  id        String            @id @default(cuid())
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  user      AppUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      ProductMemberRole

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([clientId])
}

// ──────────────────────────────────────────────────────
// Ideas Module
// ──────────────────────────────────────────────────────

model Idea {
  id          String     @id @default(cuid())
  /// @zod.string.min(1).max(200)
  title       String
  description String
  status      IdeaStatus @default(SUBMITTED)

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  author    AppUser @relation("IdeaAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String

  // RICE scoring
  riceReach      Int?
  riceImpact     Int?
  riceConfidence Float?
  riceEffort     Int?
  riceScore      Float?

  votes Int @default(0)

  // Link to the feature this idea was converted into
  convertedToItem   RoadmapItem? @relation("IdeaToFeature", fields: [convertedToItemId], references: [id])
  convertedToItemId String?      @unique

  comments Comment[]
  tags     Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([productId])
  @@index([authorId])
  @@index([status])
}

// ──────────────────────────────────────────────────────
// Roadmap Module
// ──────────────────────────────────────────────────────

model Roadmap {
  id          String  @id @default(cuid())
  /// @zod.string.min(1).max(100)
  name        String
  description String?

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  items    RoadmapItem[]
  releases Release[]

  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([productId])
}

model RoadmapItem {
  id          String            @id @default(cuid())
  /// @zod.string.min(1).max(200)
  title       String
  description String?
  status      RoadmapItemStatus @default(BACKLOG)
  priority    Int               @default(0)

  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId String

  release   Release? @relation(fields: [releaseId], references: [id])
  releaseId String?

  // Link back to the source idea (if converted from one)
  sourceIdea Idea? @relation("IdeaToFeature")

  comments Comment[]

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
  @@index([releaseId])
}

model Release {
  id          String        @id @default(cuid())
  /// @zod.string.min(1).max(100)
  name        String
  description String?
  targetDate  DateTime?
  status      ReleaseStatus @default(PLANNED)

  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapId String

  items RoadmapItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
}

// ──────────────────────────────────────────────────────
// Issues Module
// ──────────────────────────────────────────────────────

model Issue {
  id          String        @id @default(cuid())
  /// @zod.string.min(1).max(200)
  title       String
  description String
  severity    IssueSeverity @default(MEDIUM)
  status      IssueStatus   @default(OPEN)

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  reporter   AppUser  @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId String
  assignee   AppUser? @relation("IssueAssignee", fields: [assigneeId], references: [id])
  assigneeId String?

  customersAffected Int @default(0)

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([productId])
  @@index([status])
  @@index([severity])
}

// ──────────────────────────────────────────────────────
// Goals, Comments, Tags, Custom Fields
// ──────────────────────────────────────────────────────

model Goal {
  id           String  @id @default(cuid())
  /// @zod.string.min(1).max(200)
  title        String
  description  String?
  targetValue  Float?
  currentValue Float?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ActionItem {
  id          String             @id @default(cuid())
  /// @zod.string.min(1).max(200)
  title       String
  description String?
  status      ActionItemStatus   @default(NEW)
  priority    ActionItemPriority @default(MEDIUM)
  dueDate     DateTime?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  raisedBy   AppUser @relation("ActionRaisedBy", fields: [raisedById], references: [id], onDelete: Cascade)
  raisedById String

  assignee   AppUser? @relation("ActionAssignee", fields: [assigneeId], references: [id])
  assigneeId String?

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([clientId])
  @@index([assigneeId])
  @@index([status])
}

model Comment {
  id       String  @id @default(cuid())
  content  String
  author   AppUser @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId String?

  issue   Issue?  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId String?

  roadmapItem   RoadmapItem? @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)
  roadmapItemId String?

  actionItem   ActionItem? @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  actionItemId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ideaId])
  @@index([issueId])
  @@index([roadmapItemId])
  @@index([actionItemId])
  @@index([authorId])
}

model Tag {
  id    String @id @default(cuid())
  name  String
  ideas Idea[]

  @@unique([name])
}

model CustomField {
  id        String  @id @default(cuid())
  name      String
  fieldType String // "text", "number", "date", "select"
  options   Json? // For select-type fields

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@index([productId])
}

// ──────────────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  message String
  read    Boolean          @default(false)

  recipientId String // AppUser.id

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  // Optional links to related entities
  ideaId  String?
  issueId String?

  createdAt DateTime @default(now())

  @@index([recipientId, read])
  @@index([clientId])
}
